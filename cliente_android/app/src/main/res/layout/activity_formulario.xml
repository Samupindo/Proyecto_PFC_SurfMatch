<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nueva Sesión Ideal"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <EditText
            android:id="@+id/etAlias"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Alias (ej. Bañazo de invierno)"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etFecha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Fecha (ej. 2026-04-07)"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Zona del parte meteorológico:"
            android:textStyle="bold"
            android:textColor="#555555"/>

        <Spinner
            android:id="@+id/spinnerZona"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etTamano"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Tamaño en metros (ej. 2.10)"
            android:inputType="numberDecimal"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etPeriodo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Período en segundos (ej. 13)"
            android:inputType="number"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etMarea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Marea (ej. Subiendo)"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etVientoDir"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Dirección Viento (ej. NW)"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etVientoEst"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Estado Viento (ej. Glassy)"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnGuardar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Guardar Sesión"/>

    </LinearLayout>
</ScrollView>